# ─── LLM Provider ───────────────────────────────────────────────
# Gemini API key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use for error injection (default: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# ─── Local Model (optional) ────────────────────────────────────
# Set to a local OpenAI-compatible endpoint (e.g. Ollama, vLLM, llama.cpp)
LOCAL_MODEL_URL=
# Local model name (HuggingFace ID for --backend local, default: Qwen/Qwen3-8B)
LOCAL_MODEL_NAME=Qwen/Qwen3-8B

# ─── Engine Config ──────────────────────────────────────────────
# Set to 0 to disable LLM and use template fallback only
WATCHDOG_USE_LLM=1
# "gemini" | "local" — which backend to prefer
WATCHDOG_LLM_BACKEND=gemini
# Generation temperature (0.0–1.0)
WATCHDOG_TEMPERATURE=0.8
